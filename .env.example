ETH_RPC_URL=https://ethereum-rpc.publicnode.com
TTT_CONTRACT=0x26d7ad0e930b54b84c00daad077ee31ba9e2fb2e

# Optional. Needed for holder concentration via Etherscan V2.
ETHERSCAN_API_KEY=

# Optional. If set, launch alerts are pushed to Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional. Discord incoming webhook.
DISCORD_WEBHOOK_URL=

# Optional. Feishu/Lark custom bot webhook. FEISHU_SECRET is optional.
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# Optional. Email SMTP alerting.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# Confirmation delay and polling window.
CONFIRMATIONS=2
SCAN_CHUNK=2000
LOOKBACK_BLOCKS=5000
