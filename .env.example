ETH_RPC_URL=https://ethereum-rpc.publicnode.com
TTT_CONTRACT=0x26d7ad0e930b54b84c00daad077ee31ba9e2fb2e

# 可选。用于通过 Etherscan V2 补全持仓集中度。
ETHERSCAN_API_KEY=

# 可选。配置后，新发射通知会推送到 Telegram。
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 可选。Discord 频道 webhook。
DISCORD_WEBHOOK_URL=

# 可选。飞书自定义机器人 webhook，FEISHU_SECRET 可不填。
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# 可选。邮箱 SMTP 通知。
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# 确认数、单次扫描区块范围和首次回看窗口。
CONFIRMATIONS=2
SCAN_CHUNK=2000
LOOKBACK_BLOCKS=5000
